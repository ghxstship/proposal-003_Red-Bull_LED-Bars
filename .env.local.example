# Resend transactional email (https://resend.com)
# Required for /api/sign to email the executed PDF to the signer and the GHXSTSHIP team.
# If unset, the signature is still recorded and the PDF is returned for client download.
RESEND_API_KEY=

# Sender identity. Must be a verified domain in Resend before using a custom address.
# Falls back to onboarding@resend.dev (test-only, limited deliverability) if unset.
RESEND_FROM_ADDRESS="GHXSTSHIP <sos@ghxstship.pro>"
